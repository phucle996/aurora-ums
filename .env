# Application
APP_NAME=Aurora Cloud
APP_HOST=0.0.0.0
APP_PORT=3005
APP_LOG_LEVEL=info
APP_TIMEZONE=UTC
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_CREDENTIALS=true

# PostgreSQL
DATABASE_URL=postgres://aurora:27012004@localhost:5432/aurora
DB_SSLMODE=disable
DB_SSLROOTCERT=
DB_SSLKEY=
DB_SSLCERT=

# Redis
REDIS_ADDR=localhost:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_TLS_CA=
REDIS_TLS_KEY=
REDIS_TLS_CERT=
REDIS_TLS_INSECURE=false

# Tokens
ACCESS_TOKEN_SECRET=change-me-access
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=change-me-refresh
REFRESH_TOKEN_TTL=240h
OTT_SECRET=change-me-ott
OTT_TTL=15m
